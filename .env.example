# Firebase
FIREBASE_PROJECT_ID=passme-1df1e
FIREBASE_SERVICE_ACCOUNT_KEY=/app/serviceAccountKey.json

# JWT
JWT_SECRET=your-secret-key-here-min-32-chars-long
JWT_EXPIRE=7d

# Gmail API (OAuth2)
GMAIL_CLIENT_ID=xxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxx
GMAIL_REFRESH_TOKEN=xxx
GMAIL_FROM_EMAIL=your-email@gmail.com

# Google Cloud Logging
GOOGLE_CLOUD_PROJECT_ID=passme-1df1e
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account-key.json

# Telegram Bot
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_WEBHOOK_URL=https://your-render-url.onrender.com/api/telegram/webhook
TELEGRAM_ADMIN_GROUP_ID=xxx

# Server
PORT=3000
NODE_ENV=production
APP_URL=https://your-render-url.onrender.com
